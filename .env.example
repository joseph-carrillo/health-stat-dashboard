# Health Statistics Dashboard — environment template.
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# ----- Database -----
# DB_HOST is overridden to "db" inside docker-compose; "localhost" is for
# running the backend directly on the host against the Docker DB.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=doh_nir_dashboard
DB_USER=doh_admin
# Required — compose refuses to start without it.
DB_PASSWORD=doh_password_2026

# ----- Auth -----
# JWT signing secret. CHANGE THIS for any non-local deployment.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=doh-nir-dashboard-secret-key-2026-change-in-production

# ----- CORS -----
# Comma-separated allowed origins. "*" is fine for local dev; in production
# set the real frontend origin, e.g. https://dashboard.doh-ro7.gov.ph
CORS_ORIGINS=*

# ----- Frontend (dev only) -----
# Where the Vite dev server proxies /api. Compose sets this to http://backend:8000.
VITE_PROXY_TARGET=http://localhost:8000
