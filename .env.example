# Health Statistics Dashboard — environment template.
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# ----- Database -----
# DB_HOST is overridden to "db" inside docker-compose; "localhost" is for
# running the backend directly on the host against the Docker DB.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=doh_nir_dashboard
DB_USER=doh_admin
# Required — compose refuses to start without it.
DB_PASSWORD=doh_password_2026

# ----- Auth -----
# JWT signing secret. CHANGE THIS for any non-local deployment.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=doh-nir-dashboard-secret-key-2026-change-in-production

# ----- ESR reports -> Google Sheets line list -----
# Only required if/when someone submits the ESR Verification Form; read
# lazily so the app boots fine without these. See RUNBOOK.md for the
# one-time Google Cloud setup (service account + Sheet sharing) steps.
# Path (inside the container) to the service-account JSON key. Drop the
# real file at ./secrets/google-service-account.json on the host.
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json
# The target Google Sheet's ID, from its URL.
ESR_SHEET_ID=

# ----- CORS -----
# Comma-separated allowed origins. The default covers local dev (Vite :5173,
# prod-parity nginx :80). In production set ONLY the real site origin,
# e.g. https://your-dashboard-domain.com — never "*".
CORS_ORIGINS=http://localhost:5173,http://localhost

# ----- Frontend (dev only) -----
# Where the Vite dev server proxies /api. Compose sets this to http://backend:8000.
VITE_PROXY_TARGET=http://localhost:8000

# ----- Production only (docker-compose.prod.yml) -----
# Public address Caddy serves. ":80" = plain HTTP (local prod-parity testing).
# Set to the real domain (no scheme) for automatic Let's Encrypt HTTPS,
# e.g. SITE_ADDRESS=your-dashboard-domain.com
SITE_ADDRESS=:80
# Which released images `docker compose pull` fetches from GHCR (e.g. v1.0.0).
IMAGE_TAG=latest
