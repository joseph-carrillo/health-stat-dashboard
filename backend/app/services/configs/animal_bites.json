{
  "template_id": "ANIMAL_BITES",
  "template_version": "2026",
  "program_code": "INFECTIOUS_DISEASE",
  "source_file_pattern": "animal_bites_nir",
  "frequency": "quarterly",
  "psgc_column": 0,
  "location_column": 2,
  "header_row": 5,
  "data_start_row": 2,
  "stop_at_blank_psgc": true,

  "location_aliases": {
    "NIR": "1800000000", "NIRA": "1800000000",
    "Negros Island Region": "1800000000", "Negros Island Region (NIR)": "1800000000"
  },

  "display": {
    "label": "Rabies — Animal Bites & Deaths (quarterly)",
    "dqc_highlight": true,
    "id_columns": [
      { "key": "psgc", "label": "PSGC" },
      { "key": "location", "label": "Province/HUC" }
    ]
  },

  "upload": { "sub_program": "Rabies", "file_number": 1 },

  "sheet_map": { "1": "Qtr1", "2": "Qtr2", "3": "Qtr3", "4": "Qtr4" },

  "columns": [
    { "index": 3, "indicator_code": "RABIES_BITES_MALE", "is_computed": false },
    { "index": 4, "indicator_code": "RABIES_BITES_FEMALE", "is_computed": false },
    { "index": 5, "indicator_code": "RABIES_BITES_TOTAL", "is_computed": true,
      "formula": "RABIES_BITES_MALE + RABIES_BITES_FEMALE" },
    { "index": 6, "indicator_code": "RABIES_DEATHS_MALE", "is_computed": false },
    { "index": 7, "indicator_code": "RABIES_DEATHS_FEMALE", "is_computed": false },
    { "index": 8, "indicator_code": "RABIES_DEATHS_TOTAL", "is_computed": true,
      "formula": "RABIES_DEATHS_MALE + RABIES_DEATHS_FEMALE" },
    { "index": 9, "indicator_code": "RABIES_CASE_FATALITY_RATE", "is_computed": true,
      "formula": "RABIES_DEATHS_TOTAL / RABIES_BITES_TOTAL" }
  ],

  "dqc_rules": [
    { "rule_type": "over_threshold", "indicator_code": "RABIES_CASE_FATALITY_RATE", "threshold": 1.0,
      "numerator_code": "RABIES_DEATHS_TOTAL", "denominator_code": "RABIES_BITES_TOTAL",
      "message": "Rabies deaths exceed animal bites (CFR over 100%)",
      "hint": "Rabies deaths cannot exceed the number of animal bites reported. Over 100% means a value is wrong: check the source file and re-upload." }
  ],

  "notes": "Rabies animal bites & deaths — quarterly (only Q1 has data in the sample; Q2-Q4 blank). Province/HUC only (4 rows); header_row:5 (title block occupies rows 1-3, header on Excel row 6), data_start_row:2 skips the blank spacer (Excel row 7) + NIR region rollup (row 8). location_column:2 ('NIRA' in col 1). Case Fatality Rate = deaths/bites stored as a 0-1 ratio (x100 display); the source cell bakes in x100 and is blank for one row across Q2-Q4 (FLAG 1c) — we recompute from raw so that doesn't matter. Annual sheet is a SUM rollup, not ingested."
}
