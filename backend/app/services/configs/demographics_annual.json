    "id_columns": [
      { "key": "psgc", "label": "PSGC" },
      { "key": "location", "label": "Region, Province/City" }
    ]
  },

  "upload": {
    "sub_program": "Demographics",
    "file_number": 1
  },

  "sheet_map": {
    "annual": "BGY & BHS"
  },

  "columns": [
    { "index": 2, "indicator_code": "DEMO_POP", "is_computed": false },
    { "index": 3, "indicator_code": "DEMO_BGY_COUNT", "is_computed": false },
    { "index": 4, "indicator_code": "DEMO_BGY_RATIO", "is_computed": true, "formula": "DEMO_POP / DEMO_BGY_COUNT" },
    { "index": 5, "indicator_code": "DEMO_MUNIHC_COUNT", "is_computed": false },
    { "index": 6, "indicator_code": "DEMO_MUNIHC_RATIO", "is_computed": true, "formula": "DEMO_POP / DEMO_MUNIHC_COUNT" },
    { "index": 7, "indicator_code": "DEMO_CITYHC_COUNT", "is_computed": false },
