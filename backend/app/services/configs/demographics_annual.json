{
  "template_id": "DEMOGRAPHICS_ANNUAL",
  "template_version": "2026",
  "program_code": "DEMOGRAPHICS",
  "source_file_pattern": "Demographics_nir",
  "frequency": "annual",
  "psgc_column": 0,
  "location_column": 1,
  "header_row": 0,
  "data_start_row": 1,
  "stop_at_blank_psgc": true,

  "location_aliases": {
    "NIR": "1800000000",
