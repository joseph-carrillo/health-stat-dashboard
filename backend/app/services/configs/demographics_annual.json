    { "index": 11, "indicator_code": "DEMO_TOTALHC_COUNT", "is_computed": true, "formula": "DEMO_MUNIHC_COUNT + DEMO_CITYHC_COUNT + DEMO_RURALHU_COUNT" },
    { "index": 12, "indicator_code": "DEMO_TOTALHC_RATIO", "is_computed": true, "formula": "DEMO_POP / DEMO_TOTALHC_COUNT" },
    { "index": 13, "indicator_code": "DEMO_BHS_COUNT", "is_computed": false },
    { "index": 14, "indicator_code": "DEMO_BHS_RATIO", "is_computed": true, "formula": "DEMO_POP / DEMO_BHS_COUNT" }
