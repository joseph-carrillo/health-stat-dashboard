  "dqc_rules": [
    { "rule_type": "over_threshold", "indicator_code": "GER_SCREENED_PCT", "threshold": 1.0, "numerator_code": "GER_SCREENED_TOTAL", "denominator_code": "GER_POP", "message": "Senior-citizen screening coverage exceeds 100% of projected SC population", "hint": "Coverage is measured against a projected Senior Citizen population (an estimate). Over 100% usually means the screened count or the population figure in the source file is off — check and re-upload." },

    { "rule_type": "sequence", "sequence": ["GER_SCREENED_TOTAL", "GER_ATLEASTONE_TOTAL"], "message": "'At least one positive' total exceeds the number screened — impossible (it is a subset of those screened)." },

    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_MEMORY_TOTAL"], "message": "Memory-positive total exceeds 'at least one positive' — impossible (anyone positive for Memory is positive for at least one domain)." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_DEPRESSION_TOTAL"], "message": "Depression-positive total exceeds 'at least one positive' — impossible." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_POLYPHARMACY_TOTAL"], "message": "Polypharmacy-positive total exceeds 'at least one positive' — impossible." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_URININCONT_TOTAL"], "message": "Urinary-incontinence-positive total exceeds 'at least one positive' — impossible." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_FUNCCAP_TOTAL"], "message": "Functional-capacity-positive total exceeds 'at least one positive' — impossible." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_MALNUTRITION_TOTAL"], "message": "Malnutrition-positive total exceeds 'at least one positive' — impossible." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_HEARING_TOTAL"], "message": "Hearing-positive total exceeds 'at least one positive' — impossible." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_VISION_TOTAL"], "message": "Vision-positive total exceeds 'at least one positive' — impossible." },
    { "rule_type": "sequence", "sequence": ["GER_ATLEASTONE_TOTAL", "GER_FALLRISK_TOTAL"], "message": "Fall-risk-positive total exceeds 'at least one positive' — impossible." }
  ],

  "notes": "Geriatric screening file (ncd_geriatric_nir.xlsx — the 'ncd_' filename prefix is a legacy on-disk artifact; this seeds under the GERIATRIC program, not NCD). Province/HUC rollup (5 sheet rows: region + 3 provinces + Bacolod HUC; region row skipped on ingest and recomputed). Quarterly + Annual, but only quarters are ingested (Annual is a pure cross-quarter Excel rollup). psgc col 0, location NAME col 1. Male/Female split, no age brackets. No sensitive indicators. Domain percentages all divide by GER_SCREENED_TOTAL; care-plan percentage divides by GER_ATLEASTONE_TOTAL (only those with a positive finding are eligible). DQC is RE-DERIVED, not ported: the source file's 18 logical-consistency rules are all dead (anchored one row past the real 5-row data — see geriatric.md GER-1). The 'sequence' rules here re-implement the intended checks (screened >= at-least-one >= each domain) anchored to real data — they are EXPECTED to fire on the shipped Q1 sample because it genuinely violates them (e.g. City of Bacolod HUC reports Memory=8 but 'at least one positive'=0; Negros Occidental reports 35 screened, 0 at-least-one). That is the DQC correctly catching a real DOH data-entry error, not a parser fault. Second file in this program (ncd_scimmunization_nir.xlsx, Senior Citizen Immunization) is a separate later build, blocked: its shipped file is entirely zero/blank so its Influenza-denominator bug (IMM-1) can't be value-verified until DOH sends populated data."
