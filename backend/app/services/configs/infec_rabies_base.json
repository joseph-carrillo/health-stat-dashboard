{
  "template_id": "INFEC_RABIES_BASE",
  "template_version": "2026",
  "program_code": "INFECTIOUS_DISEASE",
  "source_file_pattern": "infec_rabies_nir",
  "frequency": "quarterly",
  "psgc_column": 0,
  "location_column": 2,
  "header_row": 0,
  "data_start_row": 1,
  "stop_at_blank_psgc": true,

  "location_aliases": {
    "NIR": "1800000000", "NIRA": "1800000000",
    "Negros Island Region": "1800000000", "Negros Island Region (NIR)": "1800000000"
  },

  "display": {
    "label": "Rabies — Exposure by WHO Category (quarterly)",
    "dqc_highlight": true,
    "id_columns": [
      { "key": "psgc", "label": "PSGC" },
      { "key": "location", "label": "Region, Province/City" }
    ]
  },

  "upload": { "sub_program": "Rabies", "file_number": 2 },

  "sheet_map": { "1": "Qtr1", "2": "Qtr2", "3": "Qtr3", "4": "Qtr4" },

  "columns": [
    { "index": 3, "indicator_code": "RABIES_CAT1_MALE", "is_computed": false },
    { "index": 4, "indicator_code": "RABIES_CAT1_FEMALE", "is_computed": false },
    { "index": 5, "indicator_code": "RABIES_CAT1_TOTAL", "is_computed": true,
      "formula": "RABIES_CAT1_MALE + RABIES_CAT1_FEMALE" },
    { "index": 6, "indicator_code": "RABIES_CAT2_MALE", "is_computed": false },
    { "index": 7, "indicator_code": "RABIES_CAT2_FEMALE", "is_computed": false },
    { "index": 8, "indicator_code": "RABIES_CAT2_TOTAL", "is_computed": true,
      "formula": "RABIES_CAT2_MALE + RABIES_CAT2_FEMALE" },
    { "index": 9, "indicator_code": "RABIES_CAT3_MALE", "is_computed": false },
    { "index": 10, "indicator_code": "RABIES_CAT3_FEMALE", "is_computed": false },
    { "index": 11, "indicator_code": "RABIES_CAT3_TOTAL", "is_computed": true,
      "formula": "RABIES_CAT3_MALE + RABIES_CAT3_FEMALE" },
    { "index": 12, "indicator_code": "RABIES_EXP_ALL_MALE", "is_computed": true,
      "formula": "RABIES_CAT1_MALE + RABIES_CAT2_MALE + RABIES_CAT3_MALE" },
    { "index": 13, "indicator_code": "RABIES_EXP_ALL_FEMALE", "is_computed": true,
      "formula": "RABIES_CAT1_FEMALE + RABIES_CAT2_FEMALE + RABIES_CAT3_FEMALE" },
    { "index": 14, "indicator_code": "RABIES_EXP_ALL_TOTAL", "is_computed": true,
      "formula": "RABIES_EXP_ALL_MALE + RABIES_EXP_ALL_FEMALE" }
  ],

  "dqc_rules": [],

  "notes": "Rabies exposure by WHO category (I/II/III) + all-category total — base sheet of the infec_rabies workbook. Quarterly (Q1-only data). Province/HUC (4 rows), NIR rollup skipped. All-category totals recomputed from the raw category male/female columns (Excel SUM(D,G,J) pattern). This base config is the single source of truth for category exposure counts; the a/b/d split-config siblings source their exposure denominators from these codes (via cross-config health_data lookup / re-mapped linked columns), never re-ingesting the linked columns as new data (FLAG 2d)."
}
