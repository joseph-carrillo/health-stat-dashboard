{
  "template_id": "INFEC_RABIES_SOURCE",
  "template_version": "2026",
  "program_code": "INFECTIOUS_DISEASE",
  "source_file_pattern": "infec_rabies_nir",
  "frequency": "quarterly",
  "psgc_column": 0,
  "location_column": 2,
  "header_row": 0,
  "data_start_row": 1,
  "stop_at_blank_psgc": true,

  "location_aliases": {
    "NIR": "1800000000", "NIRA": "1800000000",
    "Negros Island Region": "1800000000", "Negros Island Region (NIR)": "1800000000"
  },

  "display": {
    "label": "Rabies — Exposure by Animal Source (quarterly)",
    "dqc_highlight": true,
    "id_columns": [
      { "key": "psgc", "label": "PSGC" },
      { "key": "location", "label": "Region, Province/City" }
    ]
  },

  "upload": { "sub_program": "Rabies", "file_number": 5 },

  "sheet_map": { "1": "Qtr1d", "2": "Qtr2d", "3": "Qtr3d", "4": "Qtr4d" },

  "columns": [
    { "index": 3, "indicator_code": "RABIES_EXP_ALL_MALE", "is_computed": false },
    { "index": 4, "indicator_code": "RABIES_EXP_ALL_FEMALE", "is_computed": false },
    { "index": 5, "indicator_code": "RABIES_EXP_ALL_TOTAL", "is_computed": true,
      "formula": "RABIES_EXP_ALL_MALE + RABIES_EXP_ALL_FEMALE" },
    { "index": 6, "indicator_code": "RABIES_SRC_DOG_MALE", "is_computed": false },
    { "index": 7, "indicator_code": "RABIES_SRC_DOG_FEMALE", "is_computed": false },
    { "index": 8, "indicator_code": "RABIES_SRC_DOG_TOTAL", "is_computed": true,
      "formula": "RABIES_SRC_DOG_MALE + RABIES_SRC_DOG_FEMALE" },
    { "index": 9, "indicator_code": "RABIES_SRC_DOG_PCT", "is_computed": true,
      "formula": "RABIES_SRC_DOG_TOTAL / RABIES_EXP_ALL_TOTAL" },
    { "index": 10, "indicator_code": "RABIES_SRC_CAT_MALE", "is_computed": false },
    { "index": 11, "indicator_code": "RABIES_SRC_CAT_FEMALE", "is_computed": false },
    { "index": 12, "indicator_code": "RABIES_SRC_CAT_TOTAL", "is_computed": true,
      "formula": "RABIES_SRC_CAT_MALE + RABIES_SRC_CAT_FEMALE" },
    { "index": 13, "indicator_code": "RABIES_SRC_CAT_PCT", "is_computed": true,
      "formula": "RABIES_SRC_CAT_TOTAL / RABIES_EXP_ALL_TOTAL" },
    { "index": 14, "indicator_code": "RABIES_SRC_OTHER_MALE", "is_computed": false },
    { "index": 15, "indicator_code": "RABIES_SRC_OTHER_FEMALE", "is_computed": false },
    { "index": 16, "indicator_code": "RABIES_SRC_OTHER_TOTAL", "is_computed": true,
      "formula": "RABIES_SRC_OTHER_MALE + RABIES_SRC_OTHER_FEMALE" },
    { "index": 17, "indicator_code": "RABIES_SRC_OTHER_PCT", "is_computed": true,
      "formula": "RABIES_SRC_OTHER_TOTAL / RABIES_EXP_ALL_TOTAL" }
  ],

  "dqc_rules": [
    { "rule_type": "reconciliation", "mode": "equals",
      "parts": ["RABIES_SRC_DOG_TOTAL", "RABIES_SRC_CAT_TOTAL", "RABIES_SRC_OTHER_TOTAL"],
      "whole": "RABIES_EXP_ALL_TOTAL",
      "message": "Dog + cat + other exposures do not sum to all-category exposure",
      "hint": "Every rabies exposure should be attributed to dog, cat, or other. If the three sources do not add up to the all-category total, a source count or the total is wrong: check the source file and re-upload." }
  ],

  "notes": "Rabies exposure by animal source (group 'd' sheets Qtr1d-Qtr4d) — dog / cat / other, each as % of all-category exposure. Unlike the a/b groups, the all-category exposure columns (idx 3-5) ARE mapped here (to the same RABIES_EXP_ALL_* codes as the base config) because the source %s need that total as a within-sheet denominator; the values are identical to the base sheet's so they dedupe as unchanged on upload rather than double-counting. Reconciliation DQC (dog+cat+other == all-category total) deferred to D4."
}
