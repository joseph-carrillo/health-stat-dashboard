{
  "template_id": "INTRA_SHP",
  "template_version": "2026",
  "program_code": "MATERNAL_CARE",
  "source_file_pattern": "intra_shp_fbd__dt_do_nir",
  "frequency": "quarterly",
  "psgc_column": 0,
  "location_column": 2,
  "header_row": 0,
  "data_start_row": 1,
  "stop_at_blank_psgc": true,

  "location_aliases": {
    "NIR": "1800000000", "NIRA": "1800000000",
    "Negros Island Region": "1800000000", "Negros Island Region (NIR)": "1800000000"
  },

  "display": {
    "label": "Intra Partum — Skilled Attendant & Facility-Based Delivery",
    "dqc_highlight": true,
    "id_columns": [
      { "key": "psgc", "label": "PSGC" },
      { "key": "location", "label": "Region/PHIC" }
    ]
  },

  "upload": { "sub_program": "Intra Partum", "file_number": 1 },

  "sheet_map": { "1": "Q1a", "2": "Q2a", "3": "Q3a", "4": "Q4a" },

  "columns": [
    { "index": 3, "indicator_code": "INTRA_DELIVERIES_10_14", "is_computed": false },
    { "index": 4, "indicator_code": "INTRA_DELIVERIES_15_19", "is_computed": false },
    { "index": 5, "indicator_code": "INTRA_DELIVERIES_20_49", "is_computed": false },
    { "index": 6, "indicator_code": "INTRA_DELIVERIES_TOTAL", "is_computed": true, "formula": "INTRA_DELIVERIES_10_14 + INTRA_DELIVERIES_15_19 + INTRA_DELIVERIES_20_49" },
    { "index": 7, "indicator_code": "INTRA_SHP_PHYSICIAN", "is_computed": false },
    { "index": 8, "indicator_code": "INTRA_SHP_PHYSICIAN_PCT", "is_computed": true, "formula": "INTRA_SHP_PHYSICIAN / INTRA_DELIVERIES_TOTAL" },
    { "index": 9, "indicator_code": "INTRA_SHP_NURSE", "is_computed": false },
    { "index": 10, "indicator_code": "INTRA_SHP_NURSE_PCT", "is_computed": true, "formula": "INTRA_SHP_NURSE / INTRA_DELIVERIES_TOTAL" },
    { "index": 11, "indicator_code": "INTRA_SHP_MIDWIFE", "is_computed": false },
    { "index": 12, "indicator_code": "INTRA_SHP_MIDWIFE_PCT", "is_computed": true, "formula": "INTRA_SHP_MIDWIFE / INTRA_DELIVERIES_TOTAL" },
    { "index": 13, "indicator_code": "INTRA_SHP_TOTAL", "is_computed": true, "formula": "INTRA_SHP_PHYSICIAN + INTRA_SHP_NURSE + INTRA_SHP_MIDWIFE" },
    { "index": 14, "indicator_code": "INTRA_SHP_TOTAL_PCT", "is_computed": true, "formula": "INTRA_SHP_TOTAL / INTRA_DELIVERIES_TOTAL" },
    { "index": 15, "indicator_code": "INTRA_FBD_PUBLIC", "is_computed": false },
    { "index": 16, "indicator_code": "INTRA_FBD_PUBLIC_PCT", "is_computed": true, "formula": "INTRA_FBD_PUBLIC / INTRA_DELIVERIES_TOTAL" },
    { "index": 17, "indicator_code": "INTRA_FBD_PRIVATE", "is_computed": false },
    { "index": 18, "indicator_code": "INTRA_FBD_PRIVATE_PCT", "is_computed": true, "formula": "INTRA_FBD_PRIVATE / INTRA_DELIVERIES_TOTAL" },
    { "index": 19, "indicator_code": "INTRA_FBD_TOTAL", "is_computed": true, "formula": "INTRA_FBD_PUBLIC + INTRA_FBD_PRIVATE" },
    { "index": 20, "indicator_code": "INTRA_FBD_TOTAL_PCT", "is_computed": true, "formula": "INTRA_FBD_TOTAL / INTRA_DELIVERIES_TOTAL" }
  ],

  "dqc_rules": [
    { "rule_type": "sequence", "sequence": ["INTRA_DELIVERIES_TOTAL", "INTRA_SHP_TOTAL"], "message": "Skilled-attendant total exceeds total deliveries — impossible." },
    { "rule_type": "sequence", "sequence": ["INTRA_DELIVERIES_TOTAL", "INTRA_FBD_TOTAL"], "message": "Facility-based-delivery total exceeds total deliveries — impossible." }
  ],

  "notes": "Intra Partum File 1, Group A (skilled attendant type + facility-based delivery). Split config over the 'a' sheets (Q1a-Q4a); groups b (delivery type) and c (outcome) are separate configs (intra_dt, intra_do) over the b/c sheets of the same physical file (decision D3). Province/HUC rollup (5 rows; region skipped). 3 meta cols; location NAME col 2. INTRA1-1: the FBD percentage headers claim '/Physicians (e)' but the actual formula (and correct math) divides by Deliveries Total — this config uses INTRA_DELIVERIES_TOTAL. INTRA1-6: attendant/facility counts are NOT age-disaggregated (only the Deliveries baseline is). The shared INTRA_DELIVERIES_* baseline is also mapped by the b/c configs (cross-sheet references to this group); identical values, so the parser's skip-unchanged logic prevents double-counting on commit. Annual sheet is a pure rollup, not ingested."
}
