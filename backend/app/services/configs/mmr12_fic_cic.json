    { "index": 6, "indicator_code": "MMR1_PCT", "is_computed": true, "formula": "MMR1_TOTAL / MMR_POP_2026", "year": "current" },
    { "index": 7, "indicator_code": "IMMUN_POP_0_11M_PREV", "is_computed": false, "year": "previous" },
