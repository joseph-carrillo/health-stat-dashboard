    { "index": 11, "indicator_code": "MMR1_PREV_PCT", "is_computed": true, "formula": "MMR1_PREV_TOTAL / IMMUN_POP_0_11M_PREV", "year": "previous" },
    { "index": 12, "indicator_code": "MMR2_MALE", "is_computed": false, "year": "previous" },
    { "index": 13, "indicator_code": "MMR2_FEMALE", "is_computed": false, "year": "previous" },
    { "index": 14, "indicator_code": "MMR2_TOTAL", "is_computed": true, "formula": "MMR2_MALE + MMR2_FEMALE", "year": "previous" },
    { "index": 15, "indicator_code": "MMR2_PCT", "is_computed": true, "formula": "MMR2_TOTAL / IMMUN_POP_0_11M_PREV", "year": "previous" },
    { "index": 16, "indicator_code": "FIC_MALE", "is_computed": false, "year": "previous" },
    { "index": 17, "indicator_code": "FIC_FEMALE", "is_computed": false, "year": "previous" },
    { "index": 18, "indicator_code": "FIC_TOTAL", "is_computed": true, "formula": "FIC_MALE + FIC_FEMALE", "year": "previous" },
    { "index": 19, "indicator_code": "FIC_PCT", "is_computed": true, "formula": "FIC_TOTAL / IMMUN_POP_0_11M_PREV", "year": "previous" },
    { "index": 20, "indicator_code": "PREV_POP_MINUS_FIC", "is_computed": true, "formula": "IMMUN_POP_0_11M_PREV - FIC_TOTAL", "year": "previous" },
    { "index": 21, "indicator_code": "CIC_MALE", "is_computed": false, "year": "previous" },
    { "index": 22, "indicator_code": "CIC_FEMALE", "is_computed": false, "year": "previous" },
    { "index": 23, "indicator_code": "CIC_TOTAL", "is_computed": true, "formula": "CIC_MALE + CIC_FEMALE", "year": "previous" },
    { "index": 24, "indicator_code": "CIC_PCT", "is_computed": true, "formula": "CIC_TOTAL / PREV_POP_MINUS_FIC", "year": "previous" }
  ],

  "dqc_rules": [
    { "rule_type": "over_threshold", "indicator_code": "MMR1_PCT", "threshold": 2.0, "message": "MMR dose 1 percentage exceeds 200% of projected population" },
    { "rule_type": "over_threshold", "indicator_code": "MMR1_PREV_PCT", "threshold": 2.0, "message": "MMR dose 1 (prev year) percentage exceeds 200%" },
    { "rule_type": "over_threshold", "indicator_code": "MMR2_PCT", "threshold": 2.0, "message": "MMR dose 2 percentage exceeds 200%" },
    { "rule_type": "over_threshold", "indicator_code": "FIC_PCT", "threshold": 2.0, "message": "FIC percentage exceeds 200%" },
    { "rule_type": "over_threshold", "indicator_code": "CIC_PCT", "threshold": 2.0, "message": "CIC percentage exceeds 200%" }
  ],

  "notes": "Monthly data cols 2-24 per FHSIS layout. MMR2/FIC/CIC use previous-year population denominators per template formulas."
}
